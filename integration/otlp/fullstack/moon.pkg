import {
  "moonbitlang/async" @async,
  "moonbitlang/core/debug",
  "moonbit-community/opentelemetry" @otel,
  "moonbit-community/opentelemetry/interface/global" @global,
  "moonbit-community/opentelemetry/interface/logs" @ilogs,
  "moonbit-community/opentelemetry/interface/metrics" @imetrics,
  "moonbit-community/opentelemetry/interface/trace" @trace,
  "moonbit-community/opentelemetry/otlp" @otlp,
  "moonbit-community/opentelemetry/protocol/common/v1" @otlp_common,
  "moonbit-community/opentelemetry/protocol/logs/v1" @otlp_logs,
  "moonbit-community/opentelemetry/protocol/metrics/v1" @otlp_metrics,
  "moonbit-community/opentelemetry/protocol/trace/v1" @otlp_trace,
  "moonbit-community/opentelemetry/sdk" @sdk,
  "moonbit-community/opentelemetry/sdk/logs" @sdklogs,
  "moonbit-community/opentelemetry/sdk/metrics" @sdkmetrics,
  "moonbit-community/opentelemetry/sdk/resource" @resource,
  "moonbit-community/opentelemetry-integration-otlp/support" @support,
} for "test"

options(
  backend: [ "native" ],
  "max-concurrent-tests": 1,
)
